# =============================================================================
# Variables de entorno · XP Repuestos
# =============================================================================
# Copiar este archivo a `.env.local` (gitignored) y completar con valores reales.
# En Vercel: Settings → Environment Variables. NUNCA commitear .env.local.
# =============================================================================

# ----- Site -----
PUBLIC_SITE_URL="https://xp-repuestos.vercel.app"

# ----- Mercado Pago -----
# 1) Crear cuenta business en mercadopago.com.ar (con CUIT del comercio).
# 2) https://www.mercadopago.com.ar/developers → Tus credenciales.
# 3) Copiar Access Token (PRODUCCION o TEST).
# 4) ⚠️  EL ACCESS TOKEN NUNCA TIENE QUE SER PUBLICO. NO usar prefijo PUBLIC_.
# 5) Configurar en Vercel sin "PUBLIC_" para que NO se exponga al bundle del cliente.
MP_ACCESS_TOKEN=""

# Public Key — solo si en el futuro usamos Bricks/Checkout API en cliente.
# Hoy con Checkout Pro NO se necesita; se puede dejar vacío.
PUBLIC_MP_PUBLIC_KEY=""

# Webhook secret — generado por nosotros, también configurado en MP panel.
# Se usa para validar que los webhooks vienen realmente de MP.
# Generar con: openssl rand -hex 32
MP_WEBHOOK_SECRET=""

# ----- Email (Resend) -----
# https://resend.com — free tier 100 mails/día.
# Necesario para confirmar pedidos al cliente y avisar al admin.
RESEND_API_KEY=""

# Email "from" — debe estar verificado en Resend para evitar spam.
# Si todavía no tenés dominio configurado en Resend, podés usar onboarding@resend.dev temporalmente.
EMAIL_FROM="XP Repuestos <pedidos@xprepuestos.com.ar>"

# Email donde llegan avisos de nuevos pedidos.
ADMIN_NOTIFY_EMAIL="hola@xprepuestos.com.ar"

# ----- Auth admin futura (opcional, no usada aún) -----
# Para proteger /admin si más adelante construimos panel.
# ADMIN_PASSWORD_HASH=""        # bcrypt hash, no contraseña plana
# SESSION_SECRET=""             # HMAC secret, openssl rand -hex 32

# ----- Bot AI (Claude / Anthropic) -----
# https://console.anthropic.com/settings/keys
# Sin esta key el bot devuelve "Servicio no disponible" pero la web sigue funcionando.
ANTHROPIC_API_KEY=""
