---
import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import siteData from '@/data/site.json';
import { buildWhatsAppLink } from '@/lib/format';

const wa = buildWhatsAppLink(
  siteData.whatsapp,
  'Hola! Vengo de la web. Quería sumarme al programa mayorista, soy un (taller / local de repuestos / ferretería) ubicado en (ciudad).',
);
---

<Layout
  title="Mayorista"
  description="Programa mayorista para talleres y locales de repuestos en Argentina. Precios escalonados, plazos de pago y prioridad en stock."
>
  <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Mayorista' }]} />

  <section class="container-x">
    <div class="border-t border-[color:var(--color-ink)] pt-8 max-w-3xl">
      <span class="label-eyebrow">Programa mayorista</span>
      <h1 class="mt-3 font-display font-black uppercase text-5xl md:text-7xl leading-[0.9]">
        Sumate al<br />programa.
      </h1>
      <p class="mt-6 text-lg text-[color:var(--color-ink-soft)]/80 leading-relaxed">
        Si tenés un taller, un local de repuestos o una ferretería del rubro, podés acceder a precios mayoristas con plazos de pago y prioridad de stock. No vendemos a consumidor final con precio de mayorista — la rentabilidad la queremos para vos.
      </p>
    </div>
  </section>

  <section class="container-x mt-16 grid gap-10 lg:grid-cols-12">
    <div class="lg:col-span-7">
      <h2 class="font-display uppercase font-extrabold text-3xl mb-6">Beneficios</h2>
      <ul class="grid gap-4 md:grid-cols-2">
        {[
          { titulo: 'Precios escalonados', detalle: 'Cuanto más comprás, mejor precio. Tres niveles según volumen mensual.' },
          { titulo: 'Pago a 30 días', detalle: 'Para clientes con historial. Empezás con pago contado y subís según comportamiento.' },
          { titulo: 'Prioridad en stock', detalle: 'Cuando entra un lote, los mayoristas tienen 48 hs de preferencia antes de salir al público.' },
          { titulo: 'Asesor dedicado', detalle: 'Una sola persona te atiende para que no tengas que repetir cada pedido.' },
        ].map((b) => (
          <li class="border border-[color:var(--color-ink)]/15 p-6">
            <h3 class="font-display uppercase text-lg font-extrabold">{b.titulo}</h3>
            <p class="mt-2 text-sm text-[color:var(--color-ink-soft)]/75 leading-relaxed">{b.detalle}</p>
          </li>
        ))}
      </ul>

      <h2 class="font-display uppercase font-extrabold text-3xl mt-12 mb-6">Requisitos</h2>
      <ul class="space-y-3">
        {[
          'CUIT activo y categoría fiscal compatible (responsable inscripto o monotributo).',
          'Compra mínima inicial declarada al sumarse.',
          'Local físico o taller verificable (puede ser visita o foto).',
          'Compromiso de no comercializar a precio mayorista al consumidor final.',
        ].map((r) => (
          <li class="flex gap-3 items-start text-base">
            <span class="mt-1.5 inline-block size-1.5 rounded-full bg-[color:var(--color-rust)] shrink-0"></span>
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>

    <aside class="lg:col-span-5">
      <div class="sticky top-28 bg-[color:var(--color-ink)] text-[color:var(--color-paper)] p-8">
        <span class="label-eyebrow !text-[color:var(--color-rust)]">Cómo aplicar</span>
        <h3 class="mt-3 font-display uppercase text-3xl font-black leading-tight">
          Mandanos los datos y te respondemos en 48 hs.
        </h3>
        <p class="mt-4 text-sm text-[color:var(--color-paper)]/75 leading-relaxed">
          Lo más rápido es WhatsApp. Decinos qué tipo de comercio tenés, en qué ciudad estás y volumen aproximado mensual.
        </p>
        <div class="mt-6 flex flex-col gap-3">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-wa">
            Aplicar por WhatsApp
          </a>
          <a href={`mailto:${siteData.email}?subject=${encodeURIComponent('Aplicación mayorista — XP Repuestos')}`} class="btn btn-ghost !text-[color:var(--color-paper)] !border-[color:var(--color-paper)] hover:!bg-[color:var(--color-paper)] hover:!text-[color:var(--color-ink)]">
            Mandar por email
          </a>
        </div>
      </div>
    </aside>
  </section>
</Layout>
