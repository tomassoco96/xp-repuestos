---
import Layout from '@/layouts/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import FilterSidebar from '@/components/FilterSidebar.astro';
import { categories, getProductsByCategory } from '@/lib/products';

export const prerender = true;

export function getStaticPaths() {
  return categories.map((c) => ({
    params: { categoria: c.slug },
    props: { category: c },
  }));
}

const { category } = Astro.props;
const productos = getProductsByCategory(category.slug);
---

<Layout
  title={category.nombre}
  description={category.descripcion}
>
  <Breadcrumbs
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Tienda', href: '/tienda' },
      { label: category.nombre },
    ]}
  />

  <section class="container-x">
    <div class="border-t-2 border-[color:var(--color-ink)] pt-8 reveal">
      <span class="label-eyebrow">Categoría</span>
      <h1 class="mt-3 font-display font-black uppercase text-4xl md:text-6xl lg:text-7xl leading-[0.9]">{category.nombre}</h1>
      <p class="mt-6 max-w-2xl text-base text-[color:var(--color-ink-soft)]/80 leading-relaxed">
        {category.descripcion}
      </p>
      <p class="mt-3 text-sm text-[color:var(--color-steel)]">{productos.length} productos en esta categoría</p>
    </div>
  </section>

  <section class="container-x mt-10 mb-20">
    {productos.length === 0 ? (
      <div class="border border-dashed border-[color:var(--color-ink)]/30 p-10 text-center">
        <p class="font-display uppercase text-xl">Próximamente</p>
        <p class="mt-2 text-sm text-[color:var(--color-steel)]">
          Estamos cargando productos en esta categoría. Mientras tanto, consultanos por WhatsApp con lo que necesitás.
        </p>
      </div>
    ) : (
      <div class="grid gap-6 lg:grid-cols-[280px_1fr]">
        <FilterSidebar products={productos} />

        <div>
          <div data-xp-filter-empty class="hidden border border-dashed border-[color:var(--color-ink)]/30 p-10 text-center mb-6">
            <p class="font-display uppercase text-xl">Sin resultados con esos filtros</p>
            <p class="mt-2 text-sm text-[color:var(--color-steel)]">
              Probá ajustar los filtros o limpiarlos para ver todos los productos de la categoría.
            </p>
          </div>
          <div class="grid gap-4 grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {productos.map((p, i) => <ProductCard product={p} index={i} />)}
          </div>
        </div>
      </div>
    )}
  </section>
</Layout>
