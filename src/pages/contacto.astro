---
import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import siteData from '@/data/site.json';
import { buildWhatsAppLink } from '@/lib/format';

export const prerender = true;

const wa = buildWhatsAppLink(siteData.whatsapp, siteData.whatsapp_mensaje_default);
const direccionCompleta = `${siteData.direccion.calle}, ${siteData.direccion.ciudad}`;
const mapsLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(direccionCompleta)}`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: 'https://xp-repuestos.vercel.app/contacto',
  name: 'Contacto · XP Repuestos',
};
---

<Layout
  title="Contacto"
  description="Contactá con XP Repuestos por WhatsApp, email o visitanos en Montenegro 1627, CABA."
  schema={schema}
>
  <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Contacto' }]} />

  <section class="container-x grid gap-10 lg:grid-cols-12 mt-4 mb-20">
    <div class="lg:col-span-7 border-t border-[color:var(--color-ink)] pt-8">
      <span class="label-eyebrow">Contacto</span>
      <h1 class="mt-3 font-display font-black uppercase text-5xl md:text-7xl leading-[0.9]">
        Hablemos.
      </h1>
      <p class="mt-6 max-w-xl text-base text-[color:var(--color-ink-soft)]/80 leading-relaxed">
        El canal más rápido es WhatsApp — respondemos dentro del horario comercial el mismo día. Si preferís email, tardamos un poco más pero también llegamos.
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <a href={wa} target="_blank" rel="noopener" class="border border-[color:var(--color-ink)]/15 p-6 hover:border-[color:var(--color-ink)] transition group">
          <span class="label-eyebrow">WhatsApp</span>
          <p class="mt-2 font-display uppercase text-2xl font-extrabold group-hover:text-[color:var(--color-rust)]">{siteData.telefono}</p>
          <p class="mt-1 text-xs text-[color:var(--color-steel)]">Respuesta en horario comercial</p>
        </a>

        <a href={`mailto:${siteData.email}`} class="border border-[color:var(--color-ink)]/15 p-6 hover:border-[color:var(--color-ink)] transition group">
          <span class="label-eyebrow">Email</span>
          <p class="mt-2 font-display uppercase text-2xl font-extrabold group-hover:text-[color:var(--color-rust)] break-all">{siteData.email}</p>
          <p class="mt-1 text-xs text-[color:var(--color-steel)]">Respondemos en 24 hs hábiles</p>
        </a>

        <a href={mapsLink} target="_blank" rel="noopener" class="border border-[color:var(--color-ink)]/15 p-6 hover:border-[color:var(--color-ink)] transition group">
          <span class="label-eyebrow">Local físico</span>
          <p class="mt-2 font-display uppercase text-2xl font-extrabold group-hover:text-[color:var(--color-rust)]">{direccionCompleta}</p>
          <p class="mt-1 text-xs text-[color:var(--color-steel)]">Cómo llegar →</p>
        </a>

        <a href={siteData.redes.instagram.url} target="_blank" rel="noopener" class="border border-[color:var(--color-ink)]/15 p-6 hover:border-[color:var(--color-ink)] transition group">
          <span class="label-eyebrow">Instagram</span>
          <p class="mt-2 font-display uppercase text-2xl font-extrabold group-hover:text-[color:var(--color-rust)]">{siteData.redes.instagram.handle}</p>
          <p class="mt-1 text-xs text-[color:var(--color-steel)]">Novedades y stock</p>
        </a>
      </div>

      <h2 class="mt-12 font-display uppercase font-extrabold text-2xl">Horarios</h2>
      <ul class="mt-3 space-y-1 text-base">
        {siteData.horarios.map((h) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="text-[color:var(--color-rust)]">›</span>
            <span>{h}</span>
          </li>
        ))}
      </ul>
    </div>

    <aside class="lg:col-span-5">
      <div class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] p-8 sticky top-28">
        <h3 class="font-display uppercase text-2xl font-extrabold leading-tight">
          ¿No sabés qué repuesto necesitás?
        </h3>
        <p class="mt-4 text-sm text-[color:var(--color-paper)]/75 leading-relaxed">
          Sacale foto al repuesto roto y al modelo de tu moto. Mandanos las dos por WhatsApp y te confirmamos qué pieza es y si la tenemos.
        </p>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-wa mt-6 w-full">
          Mandar foto por WhatsApp
        </a>
      </div>
    </aside>
  </section>
</Layout>
