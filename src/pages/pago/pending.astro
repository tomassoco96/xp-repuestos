---
import Layout from '@/layouts/Layout.astro';

export const prerender = true;
---

<Layout title="Pago pendiente" description="Tu pago está siendo procesado." noindex={true}>
  <section class="container-x py-32 text-center max-w-2xl mx-auto">
    <div class="inline-flex items-center justify-center size-20 rounded-full bg-amber-50 text-amber-600 mb-6">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
    </div>

    <span class="label-eyebrow" style="color:#B45309;">Pago pendiente</span>
    <h1 class="mt-4 font-display font-black uppercase text-5xl md:text-7xl leading-[0.9]">
      Tu pago<br />
      <span class="accent-italic text-amber-600">se está procesando.</span>
    </h1>

    <p class="mt-6 max-w-md mx-auto text-base text-[color:var(--color-ink-soft)]/80 leading-relaxed">
      Algunos métodos de pago como Rapipago o Pago Fácil tardan hasta 48 hs en acreditarse. Cuando se confirme, te avisamos por mail y te llega el seguimiento del envío.
    </p>

    <div class="mt-9 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-dark">Volver al inicio</a>
    </div>
  </section>
</Layout>
