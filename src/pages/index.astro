---
import Layout from '@/layouts/Layout.astro';
import ProductCard from '@/components/ProductCard.astro';
import CategoryCard from '@/components/CategoryCard.astro';
import { categories, getFeaturedProducts, getAllBrands } from '@/lib/products';
import siteData from '@/data/site.json';
import { buildWhatsAppLink } from '@/lib/format';

const featured = getFeaturedProducts(8);
const featuredCats = categories.filter((c) => c.destacado);
const brands = getAllBrands();
const wa = buildWhatsAppLink(siteData.whatsapp, siteData.whatsapp_mensaje_default);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': 'https://xp-repuestos.vercel.app/#org',
    name: siteData.nombre,
    image: 'https://xp-repuestos.vercel.app/og-default.jpg',
    address: {
      '@type': 'PostalAddress',
      streetAddress: siteData.direccion.calle,
      addressLocality: siteData.direccion.ciudad,
      addressCountry: 'AR',
    },
    telephone: siteData.telefono,
    email: siteData.email,
    sameAs: [siteData.redes.instagram.url],
    priceRange: '$$',
    description: siteData.descripcion,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteData.nombre,
    url: 'https://xp-repuestos.vercel.app/',
  },
];
---

<Layout
  title={null}
  description={siteData.descripcion}
  schema={schema}
>
  <!-- HERO -->
  <section class="relative bg-[color:var(--color-ink)] text-[color:var(--color-paper)] overflow-hidden">
    <div class="absolute inset-0 grid-noise opacity-50" aria-hidden="true"></div>

    <div class="container-x relative grid lg:grid-cols-12 gap-10 py-20 md:py-28 items-center">
      <div class="lg:col-span-7">
        <span class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-[color:var(--color-rust)] font-bold">
          <span class="inline-block size-2 rounded-full bg-[color:var(--color-rust)] animate-pulse" aria-hidden="true"></span>
          {siteData.hero.kicker}
        </span>

        <h1 class="mt-6 font-display font-black uppercase leading-[0.85] text-[clamp(3.2rem,9vw,7.5rem)]">
          {siteData.hero.titulo_1}
          <span class="block text-[color:var(--color-rust)]">{siteData.hero.titulo_2}.</span>
        </h1>

        <p class="mt-7 max-w-xl text-base md:text-lg text-[color:var(--color-paper)]/75 leading-relaxed">
          {siteData.hero.subtitulo}
        </p>

        <div class="mt-9 flex flex-wrap gap-3">
          <a href="/tienda" class="btn btn-primary">{siteData.hero.cta_primario}</a>
          <a href={wa} target="_blank" rel="noopener" class="btn btn-ghost !text-[color:var(--color-paper)] !border-[color:var(--color-paper)] hover:!bg-[color:var(--color-paper)] hover:!text-[color:var(--color-ink)]">
            {siteData.hero.cta_secundario}
          </a>
        </div>
      </div>

      <div class="lg:col-span-5 hidden lg:block">
        <div class="relative aspect-[4/5] border border-[color:var(--color-paper)]/20 p-8">
          <div class="absolute -top-3 left-6 bg-[color:var(--color-ink)] px-3 text-[10px] uppercase tracking-widest text-[color:var(--color-paper)]/60">Catálogo vivo</div>

          <div class="grid grid-rows-3 gap-4 h-full">
            {featured.slice(0, 3).map((p) => (
              <a href={`/producto/${p.slug}`} class="flex items-center gap-4 border-b border-[color:var(--color-paper)]/10 pb-4 last:border-b-0 group">
                <div class="size-20 shrink-0 product-img">
                  <img src={p.imagen} alt="" loading="lazy" decoding="async" class="size-full object-contain p-1.5" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-[10px] uppercase tracking-widest text-[color:var(--color-rust)] font-bold">{p.marca}</p>
                  <p class="font-display uppercase font-bold text-sm leading-tight line-clamp-2 group-hover:text-[color:var(--color-rust)]">{p.nombre}</p>
                </div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[color:var(--color-paper)]/40 group-hover:text-[color:var(--color-rust)] shrink-0">
                  <path d="M5 12h14M13 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Trust bar -->
    <div class="relative border-t border-[color:var(--color-paper)]/10">
      <div class="container-x grid grid-cols-2 md:grid-cols-4 divide-x divide-[color:var(--color-paper)]/10">
        {siteData.trust_bar.map((t) => (
          <div class="px-2 py-6 text-center md:text-left first:pl-0">
            <p class="font-display font-black text-3xl md:text-4xl tabular text-[color:var(--color-paper)]">{t.valor}</p>
            <p class="mt-1 text-xs uppercase tracking-widest text-[color:var(--color-paper)]/60">{t.etiqueta}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRAND TICKER -->
  <section class="bg-[color:var(--color-paper-soft)] border-y border-[color:var(--color-ink)]/10 overflow-hidden py-6">
    <div class="ticker font-display uppercase text-base md:text-lg font-bold tracking-widest text-[color:var(--color-ink)]/70">
      {[...brands, ...brands].map((b) => (
        <span class="flex items-center gap-3">
          <span aria-hidden="true" class="text-[color:var(--color-rust)]">●</span>
          <span>{b}</span>
        </span>
      ))}
    </div>
  </section>

  <!-- CATEGORÍAS -->
  <section class="container-x py-20 md:py-28">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
      <div>
        <span class="label-eyebrow">Catálogo</span>
        <h2 class="mt-3 font-display font-black uppercase text-4xl md:text-5xl leading-none">
          Buscá lo que <span class="text-[color:var(--color-rust)]">necesitás</span>
        </h2>
      </div>
      <a href="/tienda" class="text-sm font-display uppercase tracking-widest font-bold text-[color:var(--color-rust)] hover:underline">
        Ver todos los productos →
      </a>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {featuredCats.map((c) => <CategoryCard category={c} />)}
    </div>
  </section>

  <!-- DESTACADOS -->
  <section class="bg-[color:var(--color-paper-soft)] border-y border-[color:var(--color-ink)]/10 py-20 md:py-28">
    <div class="container-x">
      <div class="flex flex-wrap items-end justify-between gap-4 mb-10">
        <div>
          <span class="label-eyebrow">Top ventas</span>
          <h2 class="mt-3 font-display font-black uppercase text-4xl md:text-5xl leading-none">
            Los que más <span class="text-[color:var(--color-rust)]">salen</span>
          </h2>
        </div>
        <a href="/tienda" class="text-sm font-display uppercase tracking-widest font-bold hover:text-[color:var(--color-rust)]">
          Ver más →
        </a>
      </div>

      <div class="grid gap-4 grid-cols-2 lg:grid-cols-4">
        {featured.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <!-- POR QUÉ -->
  <section class="container-x py-20 md:py-28">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <span class="label-eyebrow">Por qué XP</span>
        <h2 class="mt-3 font-display font-black uppercase text-4xl md:text-5xl leading-none">
          Repuesto<br />justo. <span class="text-[color:var(--color-rust)]">Bien rápido.</span>
        </h2>
        <p class="mt-6 text-base text-[color:var(--color-ink-soft)]/80 leading-relaxed max-w-md">
          No vendemos lo que no usaríamos en nuestra propia moto. Si no estás seguro de qué necesitás, mandanos foto del repuesto roto por WhatsApp y te confirmamos compatibilidad antes de cobrarte un peso.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-wa">
            Mandar foto por WhatsApp
          </a>
          <a href="/nuestra-historia" class="btn btn-ghost">Conocernos</a>
        </div>
      </div>

      <div class="lg:col-span-7 grid gap-4 md:grid-cols-2">
        {[
          { kicker: '01', titulo: 'Compatibilidad confirmada', detalle: 'Te decimos qué modelo de moto entra antes de la compra. Cero adivinanzas.' },
          { kicker: '02', titulo: 'Stock real, no foto de catálogo', detalle: 'Lo que ves publicado lo tenemos. Si no, te avisamos cuándo entra.' },
          { kicker: '03', titulo: 'Envío a todo el país', detalle: 'OCA, Andreani y Correo Argentino. Despachamos en 24/48 hs hábiles.' },
          { kicker: '04', titulo: 'Atención personalizada', detalle: 'Hablás con personas que arreglan motos, no con un bot.' },
        ].map((b) => (
          <div class="border border-[color:var(--color-ink)]/15 p-6 hover:border-[color:var(--color-ink)] transition">
            <span class="font-display font-black text-3xl text-[color:var(--color-rust)] tabular">{b.kicker}</span>
            <h3 class="mt-3 font-display uppercase font-extrabold text-xl leading-tight">{b.titulo}</h3>
            <p class="mt-2 text-sm text-[color:var(--color-ink-soft)]/75 leading-relaxed">{b.detalle}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MAYORISTA CTA -->
  <section class="bg-[color:var(--color-ink)] text-[color:var(--color-paper)] py-20 md:py-24">
    <div class="container-x grid gap-8 lg:grid-cols-12 items-center">
      <div class="lg:col-span-7">
        <span class="label-eyebrow">Mayorista</span>
        <h2 class="mt-3 font-display font-black uppercase text-4xl md:text-5xl leading-none">
          ¿Tenés un<br />taller o local?
        </h2>
        <p class="mt-6 text-base text-[color:var(--color-paper)]/75 leading-relaxed max-w-xl">
          Sumate al programa mayorista: precios escalonados por volumen, plazos de pago a 30 días para clientes con historial, y prioridad en stock nuevo.
        </p>
      </div>
      <div class="lg:col-span-5 flex flex-col gap-3">
        <a href="/mayorista" class="btn btn-primary text-base">Conocer condiciones</a>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-ghost !text-[color:var(--color-paper)] !border-[color:var(--color-paper)] hover:!bg-[color:var(--color-paper)] hover:!text-[color:var(--color-ink)] text-base">
          Hablar con un asesor
        </a>
      </div>
    </div>
  </section>
</Layout>
