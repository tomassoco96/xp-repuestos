---
import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

export const prerender = true;
---

<Layout title="Carrito" description="Tu carrito en XP Repuestos.">
  <Breadcrumbs items={[{ label: 'Inicio', href: '/' }, { label: 'Carrito' }]} />

  <section class="container-x">
    <div class="border-t-2 border-[color:var(--color-ink)] pt-8 reveal">
      <span class="label-eyebrow">Carrito</span>
      <h1 class="mt-4 font-display font-black uppercase text-5xl md:text-7xl leading-[0.9]">
        Tu <span class="accent-italic text-[color:var(--color-rust)]">carrito</span>
      </h1>
    </div>
  </section>

  <section class="container-x mt-12 mb-20">
    <p data-xp-cart-page-empty class="text-center text-[color:var(--color-steel)] py-12">
      Todavía no agregaste productos. <a href="/tienda" class="underline underline-offset-2 hover:text-[color:var(--color-rust)]">Ir al catálogo</a>.
    </p>

    <div data-xp-cart-page-content class="grid lg:grid-cols-12 gap-10 hidden">
      <ul data-xp-cart-page-items class="lg:col-span-8 space-y-4"></ul>

      <aside class="lg:col-span-4">
        <div class="lg:sticky lg:top-32 border border-[color:var(--color-line)] bg-[color:var(--color-bone)] p-6">
          <h2 class="font-display uppercase font-extrabold text-xl mb-4">Resumen</h2>
          <div class="flex justify-between mb-2">
            <span class="text-sm">Subtotal</span>
            <span data-xp-cart-page-subtotal class="font-display font-black tabular">$0</span>
          </div>
          <div class="flex justify-between mb-4 text-xs text-[color:var(--color-steel)]">
            <span>Envío</span>
            <span>Se calcula en el checkout</span>
          </div>
          <a href="/checkout" class="btn btn-primary w-full text-base">
            Ir al checkout
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <p class="text-xs text-[color:var(--color-steel)] mt-3">
            Pagás con Mercado Pago. Cuotas, tarjeta, transferencia.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <style>
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
</Layout>
