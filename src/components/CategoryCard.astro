---
import type { Categoria } from '@/lib/products';
import { getCategoryCount } from '@/lib/products';

interface Props {
  category: Categoria;
  variant?: 'default' | 'feature';
}

const { category, variant = 'default' } = Astro.props;
const count = getCategoryCount(category.slug);

const icons: Record<string, string> = {
  helmet:
    'M5 14a7 7 0 1 1 14 0v3a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-3Zm0 0h14M9 19v3M15 19v3',
  engine:
    'M5 9h2V7h4V5h2v2h4l2 2v3h2v3h-2v3l-2 2h-4v-2h-4v2H7l-2-2v-3H3v-3h2V9Z',
  bolt: 'M13 2 4 14h7l-1 8 9-12h-7l1-8Z',
  wheel:
    'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 5v10M7 12h10M9 5l6 14M5 9l14 6M5 15l14-6',
  wrench:
    'M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18l3 3 6.3-6.3a4 4 0 0 0 5.4-5.4l-2.7 2.7-2.6-2.6 2.7-2.7',
};

const iconPath = icons[category.icono] ?? icons.wrench;
---

<a
  href={`/tienda/${category.slug}`}
  class:list={[
    'group block border bg-[color:var(--color-bone)] transition-all hover:bg-[color:var(--color-ink)] hover:text-[color:var(--color-paper)]',
    variant === 'feature'
      ? 'p-8 border-[color:var(--color-ink)]'
      : 'p-6 border-[color:var(--color-ink)]/15 hover:border-[color:var(--color-ink)]',
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <span class="inline-flex size-12 items-center justify-center rounded-md bg-[color:var(--color-paper)] text-[color:var(--color-rust)] group-hover:bg-[color:var(--color-rust)] group-hover:text-[color:var(--color-paper)] transition">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={iconPath} />
      </svg>
    </span>
    <span class="font-display text-xs uppercase tracking-widest opacity-60 group-hover:opacity-90">{count} productos</span>
  </div>

  <h3 class="mt-6 font-display text-2xl md:text-3xl font-black uppercase">{category.nombre}</h3>
  <p class="mt-2 text-sm leading-relaxed opacity-80 group-hover:opacity-90">{category.descripcion}</p>

  <span class="mt-5 inline-flex items-center gap-1.5 text-xs font-display uppercase tracking-widest text-[color:var(--color-rust)] group-hover:text-[color:var(--color-paper)]">
    Ver categoría
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M13 5l7 7-7 7" />
    </svg>
  </span>
</a>
