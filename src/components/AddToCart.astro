---
/**
 * Botón Agregar al carrito (versión grande).
 * Usado en la ficha de producto. Suma 1 al carrito y abre drawer.
 */
import type { Producto } from '@/lib/products';

interface Props {
  product: Producto;
  variant?: 'primary' | 'dark';
}

const { product, variant = 'dark' } = Astro.props;
---

<button
  type="button"
  class:list={[
    'btn',
    variant === 'primary' ? 'btn-primary' : 'btn-dark',
    'text-base xp-add-to-cart',
  ]}
  data-add-slug={product.slug}
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="9" cy="21" r="1"></circle>
    <circle cx="20" cy="21" r="1"></circle>
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
  </svg>
  Agregar al carrito
</button>

<script>
  import { addToCart, openCart } from '@/lib/cart-store';

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>('.xp-add-to-cart');
    if (!btn) return;
    const slug = btn.dataset.addSlug;
    if (!slug) return;
    addToCart(slug, 1);
    openCart();
  });
</script>
