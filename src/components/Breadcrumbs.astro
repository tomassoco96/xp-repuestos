---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

// Schema BreadcrumbList — solo si hay 2+ items con la última siendo "current".
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://xp-repuestos.vercel.app';
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, siteUrl).toString() } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="container-x py-4 text-xs uppercase tracking-widest font-medium text-[color:var(--color-steel)]">
  <ol class="flex items-center gap-2 flex-wrap">
    {
      items.map((item, idx) => (
        <li class="flex items-center gap-2">
          {idx > 0 && <span aria-hidden="true">/</span>}
          {item.href ? (
            <a href={item.href} class="hover:text-[color:var(--color-rust)]">{item.label}</a>
          ) : (
            <span class="text-[color:var(--color-ink)]">{item.label}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
